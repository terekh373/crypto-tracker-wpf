<Page x:Class="CryptoTracker.Views.CoinDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converters="clr-namespace:CryptoTracker.Converters"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      Background="{DynamicResource BackgroundBrush}"
      Title="Coin Detail">

    <Page.Resources>
        <converters:PriceChangeColorConverter x:Key="PriceChangeColor"/>
        <converters:PriceChangeSignConverter x:Key="PriceChangeSign"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="30,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Loading -->
            <TextBlock Grid.Row="0"
                       Text="Loading..."
                       FontSize="16"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,40"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

            <!-- Error -->
            <Border Grid.Row="0"
                    Background="#33EF4444" BorderBrush="#FFEF4444"
                    BorderThickness="1" CornerRadius="6" Padding="15,10"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#FFEF4444" FontSize="13"/>
            </Border>

            <!-- Content visible only when not loading -->
            <StackPanel Grid.Row="0"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">

                <!-- Back button + header -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="← Back"
                            Command="{Binding GoBackCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{DynamicResource AccentBrush}"
                            FontSize="14" Cursor="Hand"
                            Margin="0,0,20,0"/>

                    <Image Grid.Column="1"
                           Source="{Binding Coin.Image.Large}"
                           Width="40" Height="40"
                           Margin="0,0,12,0"/>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Coin.Name}"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding Coin.Symbol}"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Grid>

                <!-- Price stats row -->
                <Grid Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Current price -->
                    <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="10" Padding="18,14" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Current Price" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding Coin.MarketData.CurrentPrice[usd], StringFormat=${0:N2}}"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- 24h change -->
                    <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="10" Padding="18,14" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="24h Change" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding Coin.MarketData.PriceChangePercentage24h, Converter={StaticResource PriceChangeSign}}"
                                       FontSize="20" FontWeight="Bold" Margin="0,4,0,0"
                                       Foreground="{Binding Coin.MarketData.PriceChangePercentage24h, Converter={StaticResource PriceChangeColor}}"/>
                        </StackPanel>
                    </Border>

                    <!-- Market cap -->
                    <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="10" Padding="18,14" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Market Cap" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding Coin.MarketData.MarketCap[usd], StringFormat=${0:N0}}"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- 24h volume -->
                    <Border Grid.Column="3" Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="10" Padding="18,14">
                        <StackPanel>
                            <TextBlock Text="24h Volume" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding Coin.MarketData.TotalVolume[usd], StringFormat=${0:N0}}"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Chart section -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="10"
                        Padding="20" Margin="0,0,0,25">
                    <StackPanel>
                        <!-- Chart header + period buttons -->
                        <Grid Margin="0,0,0,15">
                            <TextBlock Text="Price Chart"
               FontSize="16" FontWeight="SemiBold"
               Foreground="{DynamicResource TextPrimaryBrush}"
               VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                                <Button Content="1D" Margin="4,0" Padding="10,5" Cursor="Hand"
                Command="{Binding ChangePeriodCommand}" CommandParameter="1"
                BorderThickness="0">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="{DynamicResource SurfaceVariantBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedDays}" Value="1">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Content="7D" Margin="4,0" Padding="10,5" Cursor="Hand"
                Command="{Binding ChangePeriodCommand}" CommandParameter="7"
                BorderThickness="0">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="{DynamicResource SurfaceVariantBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedDays}" Value="7">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Content="30D" Margin="4,0" Padding="10,5" Cursor="Hand"
                Command="{Binding ChangePeriodCommand}" CommandParameter="30"
                BorderThickness="0">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="{DynamicResource SurfaceVariantBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedDays}" Value="30">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Content="1Y" Margin="4,0" Padding="10,5" Cursor="Hand"
                Command="{Binding ChangePeriodCommand}" CommandParameter="365"
                BorderThickness="0">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="{DynamicResource SurfaceVariantBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedDays}" Value="365">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                            </StackPanel>
                        </Grid>


                        <!-- LiveCharts chart -->
                        <lvc:CartesianChart
                            Series="{Binding Series}"
                            XAxes="{Binding XAxes}"
                            YAxes="{Binding YAxes}"
                            Height="280"
                            Background="Transparent"/>
                    </StackPanel>
                </Border>

                <!-- Markets / exchanges table -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="10" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Markets"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,0,0,12"/>

                        <!-- Table header -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Exchange"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="Pair"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="2" Text="Price"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Grid>

                        <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,8"/>

                        <!-- Table rows -->
                        <ItemsControl ItemsSource="{Binding Markets}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Market.Name}"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Base}"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Last, StringFormat=${0:N4}}"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
