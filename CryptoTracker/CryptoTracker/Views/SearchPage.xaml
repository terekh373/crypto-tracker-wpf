<Page x:Class="CryptoTracker.Views.SearchPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converters="clr-namespace:CryptoTracker.Converters"
      Background="{DynamicResource BackgroundBrush}"
      Title="Search">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </Page.Resources>

    <Grid Margin="30,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="← Back"
                    Command="{Binding GoBackCommand}"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="{DynamicResource AccentBrush}"
                    FontSize="14" Cursor="Hand"
                    Margin="0,0,20,0"/>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}">
                    <Run Text="Results for: "/>
                    <Run Text="{Binding Query}" Foreground="{DynamicResource AccentBrush}"/>
                </TextBlock>
            </StackPanel>
        </Grid>

        <!-- Loading -->
        <TextBlock Grid.Row="1"
                   Text="Searching..."
                   FontSize="15"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Margin="0,10"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

        <!-- Error -->
        <Border Grid.Row="1"
                Background="#33EF4444" BorderBrush="#FFEF4444"
                BorderThickness="1" CornerRadius="6" Padding="15,10" Margin="0,0,0,15"
                Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#FFEF4444" FontSize="13"/>
        </Border>

        <!-- No results message -->
        <TextBlock Grid.Row="2"
                   Text="No cryptocurrencies found. Try a different search term."
                   FontSize="14"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Margin="0,10">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsLoading}" Value="False"/>
                                <Condition Binding="{Binding HasResults}" Value="False"/>
                                <Condition Binding="{Binding HasError}" Value="False"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible"/>
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Results list -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Results}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="10"
                                Margin="0,0,0,10" Cursor="Hand">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource SurfaceVariantBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding DataContext.OpenCoinDetailCommand,
                                                        RelativeSource={RelativeSource AncestorType=Page}}"
                                              CommandParameter="{Binding}"/>
                            </Border.InputBindings>

                            <Grid Margin="18,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="45"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Coin icon -->
                                <Image Grid.Column="0"
                                       Source="{Binding Thumb}"
                                       Width="32" Height="32"
                                       VerticalAlignment="Center"/>

                                <!-- Name + symbol -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding Symbol}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>

                                <!-- Rank badge -->
                                <Border Grid.Column="2"
                                        Background="{DynamicResource SurfaceVariantBrush}"
                                        CornerRadius="5" Padding="8,4"
                                        VerticalAlignment="Center">
                                    <TextBlock FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}">
                                        <Run Text="Rank #"/>
                                        <Run Text="{Binding MarketCapRank}"/>
                                    </TextBlock>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
