<Page x:Class="CryptoTracker.Views.CoinsListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converters="clr-namespace:CryptoTracker.Converters"
      xmlns:vm="clr-namespace:CryptoTracker.ViewModels"
      Background="{DynamicResource BackgroundBrush}"
      Title="Top Cryptocurrencies">

    <Page.Resources>
        <converters:PriceChangeColorConverter x:Key="PriceChangeColor"/>
        <converters:PriceChangeSignConverter x:Key="PriceChangeSign"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </Page.Resources>

    <Grid Margin="30,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Top 10 Cryptocurrencies"
                       FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Ranked by market capitalization"
                       FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Error message -->
        <Border Grid.Row="1"
                Background="#33EF4444"
                BorderBrush="#FFEF4444"
                BorderThickness="1"
                CornerRadius="6"
                Padding="15,10"
                Margin="0,0,0,15"
                Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#FFEF4444"
                       FontSize="13"/>
        </Border>

        <!-- Loading spinner -->
        <StackPanel Grid.Row="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="Loading..."
                       FontSize="16"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Coins list -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">
            <ItemsControl ItemsSource="{Binding Coins}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Margin="0,0,0,10"
                                Cursor="Hand">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource SurfaceVariantBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <!-- Clickable overlay -->
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding DataContext.OpenCoinDetailCommand,
                                                        RelativeSource={RelativeSource AncestorType=Page}}"
                                              CommandParameter="{Binding}"/>
                            </Border.InputBindings>

                            <Grid Margin="20,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="35"/>
                                    <ColumnDefinition Width="45"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="130"/>
                                </Grid.ColumnDefinitions>

                                <!-- Rank -->
                                <TextBlock Grid.Column="0"
                                           Text="{Binding MarketCapRank}"
                                           FontSize="14"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>

                                <!-- Coin icon -->
                                <Image Grid.Column="1"
                                       Source="{Binding Image}"
                                       Width="32" Height="32"
                                       VerticalAlignment="Center"/>

                                <!-- Name and symbol -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding Symbol, StringFormat={}{0:U}}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>

                                <!-- Price -->
                                <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                    <TextBlock Text="Price"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding CurrentPrice, StringFormat=${0:N2}}"
                                               FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>

                                <!-- 24h change -->
                                <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                    <TextBlock Text="24h Change"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding PriceChangePercentage24h, Converter={StaticResource PriceChangeSign}}"
                                               FontSize="15" FontWeight="SemiBold"
                                               Foreground="{Binding PriceChangePercentage24h, Converter={StaticResource PriceChangeColor}}"/>
                                </StackPanel>

                                <!-- Market cap -->
                                <StackPanel Grid.Column="5" VerticalAlignment="Center">
                                    <TextBlock Text="Market Cap"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding MarketCap, StringFormat=${0:N0}}"
                                               FontSize="13"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
