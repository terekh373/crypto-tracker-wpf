<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background colors -->
    <Color x:Key="BackgroundColor">#FFF5F5F5</Color>
    <Color x:Key="SurfaceColor">#FFFFFFFF</Color>
    <Color x:Key="SurfaceVariantColor">#FFEEEEEE</Color>
    <Color x:Key="BorderColor">#FFDDDDDD</Color>
    <Color x:Key="InputBackgroundColor">#FFFAFAFA</Color>

    <!-- Text colors -->
    <Color x:Key="TextPrimaryColor">#FF1A1A1A</Color>
    <Color x:Key="TextSecondaryColor">#FF666666</Color>

    <!-- Accent -->
    <Color x:Key="AccentColor">#FFF7931A</Color>

    <!-- Semantic colors -->
    <Color x:Key="PositiveColor">#FF22C55E</Color>
    <Color x:Key="NegativeColor">#FFEF4444</Color>

    <!-- Brushes derived from colors above -->
    <SolidColorBrush x:Key="BackgroundBrush"      Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush"         Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceVariantBrush"  Color="{StaticResource SurfaceVariantColor}"/>
    <SolidColorBrush x:Key="BorderBrush"          Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="{StaticResource InputBackgroundColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"     Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"   Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="AccentBrush"          Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="PositiveBrush"        Color="{StaticResource PositiveColor}"/>
    <SolidColorBrush x:Key="NegativeBrush"        Color="{StaticResource NegativeColor}"/>

</ResourceDictionary>
